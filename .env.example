# ========================================================
# Abysalto API example environment file (local/manual run)
# Copy to .env and replace placeholder values.
# Never commit real secrets.
# ========================================================

# --------------------------------------------------------------------
# Core app
# --------------------------------------------------------------------
APP_NAME="Abysalto Document QA"
ENV="dev"
LOG_LEVEL="INFO"
LOG_FORMAT="text"
LOG_JSON_INCLUDE_EXC_INFO="false"
DATA_DIR="./data"
UPLOAD_ROOT=""
CACHE_ROOT=""

# --------------------------------------------------------------------
# Database / Redis
# Local development defaults use SQLite and local Redis.
# --------------------------------------------------------------------
DATABASE_URL="sqlite:///./data/app.db"
REDIS_URL="redis://localhost:6379/0"

# --------------------------------------------------------------------
# Auth / session
# Replace these with long random values in every real environment.
# --------------------------------------------------------------------
JWT_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES="60"
PASSWORD_MIN_LENGTH="8"

SESSION_COOKIE_NAME="docqa_session"
SESSION_COOKIE_SECRET="CHANGE_ME_TO_ANOTHER_LONG_RANDOM_SECRET"
SESSION_COOKIE_SECURE="false"
SESSION_COOKIE_SAMESITE="lax"
SESSION_COOKIE_MAX_AGE_SECONDS="604800"

# --------------------------------------------------------------------
# Network / CORS
# --------------------------------------------------------------------
CORS_ALLOW_ORIGINS='["http://localhost:3000","http://127.0.0.1:3000","http://localhost:8501","http://127.0.0.1:8501"]'
TRUSTED_PROXIES='["127.0.0.1","::1"]'

# --------------------------------------------------------------------
# Upload / processing
# --------------------------------------------------------------------
MAX_UPLOAD_MB="25"
MAX_FILES_PER_REQUEST="10"
UPLOAD_AUTO_PROCESS="true"
UPLOAD_PROCESSING_MODE="sync"
ENABLE_DEDUP="true"
MAX_PDF_PAGES="250"
TEXT_EMPTY_MIN_CHARS="20"

# --------------------------------------------------------------------
# OCR
# --------------------------------------------------------------------
EASYOCR_LANGS='["en"]'
EASYOCR_GPU="false"
OCR_FALLBACK_ENABLED="true"
OCR_DPI="200"
MAX_OCR_PAGES="250"
MAX_IMAGE_PIXELS="20000000"

# --------------------------------------------------------------------
# Chunking / retrieval
# --------------------------------------------------------------------
CHUNK_SIZE_CHARS="1100"
CHUNK_OVERLAP_CHARS="180"
MAX_CHUNKS_PER_DOC="5000"
CHUNK_SEPARATORS='["\n\n","\n",". "," ",""]'
CHUNK_MIN_CHARS="180"
DEFAULT_TOP_K="5"
MAX_TOP_K="20"
RETRIEVAL_CANDIDATE_MULTIPLIER="4"
RETRIEVAL_EXCERPT_CHARS="420"
RETRIEVAL_MAX_SENTENCES_PER_CHUNK="3"
RETRIEVAL_MIN_LEXICAL_SCORE="0.05"
MAX_QUESTION_CHARS="2000"

# --------------------------------------------------------------------
# Local ML models
# --------------------------------------------------------------------
EMBEDDING_MODEL_NAME="sentence-transformers/all-MiniLM-L6-v2"
EMBEDDING_BATCH_SIZE="64"
EMBEDDING_NORMALIZE="true"
MAX_CHUNKS_TO_EMBED="5000"
NER_MODEL_NAME="en_core_web_sm"
MAX_ENTITIES="50"
HF_TOKEN=""

# --------------------------------------------------------------------
# Answer synthesis
# QA_USE_OPENAI=false lets the API run without an OpenAI key by using
# the built-in heuristic answer fallback from retrieved evidence.
# --------------------------------------------------------------------
QA_USE_OPENAI="false"
OPENAI_API_KEY=""
QA_MODEL_NAME="gpt-4o-mini"
OPENAI_BASE_URL=""
OPENAI_ORGANIZATION=""
OPENAI_TIMEOUT_SECONDS="60"
OPENAI_MAX_OUTPUT_TOKENS="350"
QA_MAX_CONTENT_CHARS="4000"
QA_MIN_SCORE="0.18"
QA_EXTRACTIVE_DOC_LIMIT="2"
QA_MIN_EVIDENCE_SCORE="0.20"
QA_MAX_EVIDENCE_SENTENCES="5"
QA_MIN_ANSWER_CHARS="3"
QA_MAX_SENTENCES="4"
QA_SUMMARY_MAX_SENTENCES="3"
QA_PURPOSE_MAX_SENTENCES="2"
QA_FIELD_MAX_SENTENCES="2"

# --------------------------------------------------------------------
# Cache / rate limiting
# --------------------------------------------------------------------
ENABLE_CACHE="true"
CACHE_TTL_SECONDS="3600"
ENABLE_SEMANTIC_CACHE="true"
SEMANTIC_CACHE_THRESHOLD="0.75"
ENABLE_RATE_LIMITING="true"
RATE_LIMIT_WINDOW_SECONDS="60"
ASK_RATE_LIMIT_PER_MIN="60"
UPLOAD_RATE_LIMIT_PER_MIN="10"
LOGIN_RATE_LIMIT_PER_MIN="10"

# --------------------------------------------------------------------
# Health readiness
# --------------------------------------------------------------------
HEALTH_READY_REQUIRED_SERVICES='["embedding","qa","ner"]'

# --------------------------------------------------------------------
# Streamlit UI convenience defaults
# --------------------------------------------------------------------
STREAMLIT_API_BASE_URL="http://127.0.0.1:8000"
STREAMLIT_REQUEST_TIMEOUT_SEC="60"
