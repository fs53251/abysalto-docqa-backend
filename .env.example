APP_NAME="DocQA API"
ENV="dev"
LOG_LEVEL="INFO"
DATA_DIR="./data"
JWT_SECRET="CHANGE_ME"
SESSION_COOKIE_SECRET="CHANGE_ME_TOO"
DATABASE_URL="sqlite:///./data/app.db"
REDIS_URL="redis://localhost:6379/0"
CORS_ALLOW_ORIGINS='["http://localhost:3000","http://127.0.0.1:3000","http://localhost:8501","http://127.0.0.1:8501"]'

# Upload / processing
MAX_UPLOAD_MB="25"
MAX_FILES_PER_REQUEST="10"
UPLOAD_AUTO_PROCESS="true"
UPLOAD_PROCESSING_MODE="sync"
ENABLE_DEDUP="true"

# Models
EMBEDDING_MODEL_NAME="sentence-transformers/all-MiniLM-L6-v2"
QA_MODEL_NAME="distilbert-base-cased-distilled-squad"
NER_MODEL_NAME="en_core_web_sm"
HF_TOKEN=""

# Cache / rate limit
ENABLE_CACHE="true"
ENABLE_SEMANTIC_CACHE="true"
CACHE_TTL_SECONDS="3600"
ENABLE_RATE_LIMITING="true"
ASK_RATE_LIMIT_PER_MIN="60"
UPLOAD_RATE_LIMIT_PER_MIN="10"
LOGIN_RATE_LIMIT_PER_MIN="10"

# Streamlit UI convenience defaults
STREAMLIT_API_BASE_URL="http://127.0.0.1:8000"
STREAMLIT_REQUEST_TIMEOUT_SEC="60"

# Docker Compose example overrides
# ENV="prod"
# DATABASE_URL="postgresql+psycopg://docqa:docqa@db:5432/docqa"
# REDIS_URL="redis://redis:6379/0"
# POSTGRES_DB="docqa"
# POSTGRES_USER="docqa"
# POSTGRES_PASSWORD="docqa"
# PRELOAD_MODELS_ON_STARTUP="false"