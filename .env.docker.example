# ========================================================
# Docker Compose example environment file
# Copy to .env before running docker compose.
# ========================================================

APP_NAME="Abysalto Document QA"
ENV="prod"
LOG_LEVEL="INFO"
LOG_FORMAT="json"
LOG_JSON_INCLUDE_EXC_INFO="false"

POSTGRES_DB="docqa"
POSTGRES_USER="docqa"
POSTGRES_PASSWORD="CHANGE_ME_DATABASE_PASSWORD"
DATABASE_URL="postgresql+psycopg://docqa:CHANGE_ME_DATABASE_PASSWORD@db:5432/docqa"
REDIS_URL="redis://redis:6379/0"

JWT_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"
SESSION_COOKIE_SECRET="CHANGE_ME_TO_ANOTHER_LONG_RANDOM_SECRET"
SESSION_COOKIE_NAME="docqa_session"
SESSION_COOKIE_SECURE="true"
SESSION_COOKIE_SAMESITE="lax"
SESSION_COOKIE_MAX_AGE_SECONDS="604800"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES="60"
PASSWORD_MIN_LENGTH="8"

QA_USE_OPENAI="false"
OPENAI_API_KEY=""
QA_MODEL_NAME="gpt-4o-mini"
OPENAI_TIMEOUT_SECONDS="60"
OPENAI_MAX_OUTPUT_TOKENS="350"

PRELOAD_MODELS_ON_STARTUP="false"
RUN_MIGRATIONS="true"
WAIT_FOR_DEPENDENCIES_TIMEOUT="90"

STREAMLIT_API_BASE_URL="http://api:8000"
STREAMLIT_REQUEST_TIMEOUT_SEC="60"
